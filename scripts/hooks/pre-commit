#!/bin/sh
# Pre-commit hook: auto-regenerate agent snapshots when agent configs or MD files change.
#
# Install:
#   ./scripts/install-hooks.sh
#   (or manually: git config core.hooksPath scripts/hooks)

REPO_ROOT="$(git rev-parse --show-toplevel)"
SNAPSHOT_SCRIPT="$REPO_ROOT/generate_agent_snapshots.js"
SNAPSHOTS_DIR="$REPO_ROOT/snapshots"

# Check if any staged files are JSON configs, MD instructions, or the generator itself
STAGED_FILES=$(git diff --cached --name-only)

NEEDS_REGEN=false
for f in $STAGED_FILES; do
    case "$f" in
        *.json|*.md|generate_agent_snapshots.js|scripts/hooks/*)
            NEEDS_REGEN=true
            break
            ;;
    esac
done

if [ "$NEEDS_REGEN" = "false" ]; then
    exit 0
fi

if ! command -v node >/dev/null 2>&1; then
    echo "⚠️  node not found. Skipping snapshot regeneration."
    exit 0
fi

echo "🔄 Regenerating agent snapshots..."
node "$SNAPSHOT_SCRIPT"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo "❌ Snapshot generation failed. Fix errors above and retry."
    exit 1
fi

# Stage any updated snapshots so they are included in the same commit
UPDATED_SNAPSHOTS=$(git diff --name-only "$SNAPSHOTS_DIR" 2>/dev/null)
UNTRACKED_SNAPSHOTS=$(git ls-files --others --exclude-standard "$SNAPSHOTS_DIR" 2>/dev/null)

if [ -n "$UPDATED_SNAPSHOTS" ] || [ -n "$UNTRACKED_SNAPSHOTS" ]; then
    git add "$SNAPSHOTS_DIR"
    echo "✅ Snapshots regenerated and staged automatically."
    if [ -n "$UPDATED_SNAPSHOTS" ]; then
        echo "   Modified:"
        echo "$UPDATED_SNAPSHOTS" | sed 's/^/      /'
    fi
    if [ -n "$UNTRACKED_SNAPSHOTS" ]; then
        echo "   New:"
        echo "$UNTRACKED_SNAPSHOTS" | sed 's/^/      /'
    fi
fi

exit 0
